# Loaded by Vite when mode is `development` (i.e., `npm run dev` and `vitest`).
# NOT loaded for `vite build` / `vite preview` — those use `production` mode.
# Committed to the repo so cloning + `npm run dev` Just Works against the
# local Firebase emulator. Developer overrides go in `.env.development.local`
# (gitignored). See web/CLAUDE.md.

VITE_USE_FIREBASE_EMULATOR=true
