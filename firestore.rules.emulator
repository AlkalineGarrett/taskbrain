rules_version = '2';
// Permissive rules for the local Firebase emulator only. Any signed-in
// (including anonymous) user can read/write any path. The production
// allowlist lives in firestore.rules and is deployed separately.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
