rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ==================== Helper Functions ====================

    // Allowlist of permitted user IDs
    function isAllowedUser() {
      return request.auth.uid == 'USER_ID_1' || request.auth.uid == 'USER_ID_2';
    }

    // Check if user is authenticated and allowed
    function isAuthenticated() {
      return request.auth != null && isAllowedUser();
    }

    // Get the current user's UID
    function currentUserId() {
      return request.auth.uid;
    }

    // Check if the incoming document's userId field matches the current user
    function incomingDataBelongsToUser() {
      return request.resource.data.userId == currentUserId();
    }

    // Check if the existing document's userId field matches the current user
    function existingDataBelongsToUser() {
      return resource.data.userId == currentUserId();
    }

    // Check if user owns the path (for /users/{userId}/... collections)
    function userOwnsPath(userId) {
      return userId == currentUserId();
    }

    // ==================== Notes Collection ====================

    match /notes/{noteId} {
      allow create: if isAuthenticated() && incomingDataBelongsToUser();
      allow read: if isAuthenticated() && (resource == null || existingDataBelongsToUser());
      allow update, delete: if isAuthenticated() && existingDataBelongsToUser();

      // Directive results subcollection. Each doc carries its own `userId`
      // field (stamped by DirectiveResultRepository on write), so we can
      // enforce ownership against the doc itself instead of doing a billed
      // `get()` of the parent note on every access. The previous form —
      // `get(/databases/.../notes/$(noteId)).data.userId == currentUserId()`
      // — added one rules-engine read per directive results read or write,
      // amplifying the project's billed read count.
      //
      // `list` (snapshot listener over the whole subcollection) trusts the
      // user-allowlist gate from `isAuthenticated()`, since per-doc
      // `resource.data.userId` predicates would force every listener query
      // to add a `.where('userId', '==', uid)` filter. Per-doc operations
      // (`get`, `update`, `delete`) still check the doc's own userId.
      match /directiveResults/{directiveHash} {
        allow create: if isAuthenticated() && incomingDataBelongsToUser();
        allow list: if isAuthenticated();
        // resource.data.userId may be missing on legacy docs created before
        // the userId stamp; allow access in that case so cached results
        // remain visible until they're re-written. New writes always include
        // userId, so legacy docs disappear naturally as directives re-run.
        allow get, update, delete: if isAuthenticated() &&
          (!('userId' in resource.data) || existingDataBelongsToUser());
      }
    }

    // ==================== User-scoped subcollections ====================

    // Single recursive rule for everything under /users/{userId}/. Covers
    // alarms, recurringAlarms, schedules, scheduleExecutions, openTabs,
    // searchHistory, and any future user-scoped subcollection at any depth.
    // The predicate is path-based (auth uid vs. wildcard userId), so it's
    // evaluable up-front for both single-doc gets and collection queries.
    match /users/{userId}/{document=**} {
      allow read, write: if isAuthenticated() && userOwnsPath(userId);
    }
  }
}
